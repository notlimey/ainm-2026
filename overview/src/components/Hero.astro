---
interface Props {
  badge: string;
  title: string;
  highlight?: string;
  subtitle: string;
}
const { badge, title, highlight, subtitle } = Astro.props;
---

<div class="hero">
  <div class="hero-badge">{badge}</div>
  <h1>{title}{highlight && <><br/><span class="accent">{highlight}</span></>}</h1>
  <p>{subtitle}</p>
</div>

<style>
  .hero {
    position: relative;
    padding: 80px 24px 60px;
    text-align: center;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-dim);
    margin-bottom: 20px;
    letter-spacing: 0.5px;
  }

  .hero h1 {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 800;
    letter-spacing: -1.5px;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero h1 .accent { color: var(--accent); }

  .hero p {
    font-size: 18px;
    color: var(--text-dim);
    max-width: 600px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .hero { padding: 48px 16px 40px; }
  }
</style>
