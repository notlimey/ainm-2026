---
interface Row {
  terrain: string;
  model: string;
  blend: string;
  best?: boolean;
}
interface Props {
  rows: Row[];
}
const { rows } = Astro.props;
---

<div class="table-container">
  <h3>Optimal Per-Class Model Blend</h3>
  <table class="model-table">
    <thead>
      <tr>
        <th>Terrain Class</th>
        <th>Best Model</th>
        <th>Blend</th>
      </tr>
    </thead>
    <tbody>
      {rows.map(row => (
        <tr>
          <td>{row.terrain}</td>
          <td>{row.model}</td>
          <td class:list={["score", { best: row.best }]}>{row.blend}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .table-container {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 32px;
  }

  h3 {
    margin-bottom: 16px;
    font-size: 15px;
  }

  .model-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .model-table th {
    text-align: left;
    padding: 12px 16px;
    font-size: 12px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border);
    font-weight: 500;
  }

  .model-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
  }

  .model-table tr:last-child td { border-bottom: none; }

  .score {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
  }

  .best { color: var(--green); }
</style>
