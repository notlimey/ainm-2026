---
interface Props {
  title?: string;
}
const { title = "NM i AI 2026 — Overview" } = Astro.props;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <title>{title}</title>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap');

    * { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0a0f;
      --surface: #12121a;
      --surface-2: #1a1a28;
      --border: #2a2a3a;
      --text: #e0e0ee;
      --text-dim: #8888aa;
      --accent: #6366f1;
      --accent-glow: rgba(99, 102, 241, 0.15);
      --green: #22c55e;
      --amber: #f59e0b;
      --red: #ef4444;
      --blue: #3b82f6;
    }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .section {
      margin-bottom: 80px;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 32px;
    }

    .section-number {
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px;
      color: var(--accent);
      background: var(--accent-glow);
      padding: 4px 10px;
      border-radius: 6px;
      font-weight: 600;
    }

    .section h2 {
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.5px;
    }

    .section-subtitle {
      font-size: 14px;
      color: var(--text-dim);
      margin-left: auto;
      font-family: 'JetBrains Mono', monospace;
    }

    .section-desc {
      color: var(--text-dim);
      font-size: 16px;
      max-width: 800px;
      margin-bottom: 32px;
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 16px;
      margin-bottom: 32px;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      transition: border-color 0.2s;
    }

    .card:hover { border-color: var(--accent); }

    .card h3 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .card p {
      font-size: 14px;
      color: var(--text-dim);
      line-height: 1.6;
    }

    .card-tag {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 4px;
      font-weight: 600;
      font-family: 'JetBrains Mono', monospace;
    }

    .tag-cpp { background: #1e3a5f; color: #60a5fa; }
    .tag-ts { background: #1e3a2f; color: #4ade80; }
    .tag-python { background: #3a3a1e; color: #facc15; }

    .tech-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 32px;
    }

    .tech-pill {
      padding: 6px 14px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 100px;
      font-size: 13px;
      color: var(--text-dim);
      font-family: 'JetBrains Mono', monospace;
    }

    .challenge-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px;
      margin-bottom: 24px;
    }

    .challenge-card h3 {
      font-size: 22px;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .challenge-card .subtitle {
      color: var(--text-dim);
      font-size: 14px;
      margin-bottom: 20px;
    }

    .result-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 8px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px;
      font-weight: 600;
      margin-right: 8px;
      margin-bottom: 8px;
    }

    .result-badge.gold { background: rgba(245, 158, 11, 0.15); color: var(--amber); border: 1px solid rgba(245, 158, 11, 0.3); }
    .result-badge.silver { background: rgba(148, 163, 184, 0.15); color: #94a3b8; border: 1px solid rgba(148, 163, 184, 0.3); }
    .result-badge.blue { background: rgba(59, 130, 246, 0.15); color: var(--blue); border: 1px solid rgba(59, 130, 246, 0.3); }

    .key-points {
      list-style: none;
      margin-top: 16px;
    }

    .key-points li {
      padding: 6px 0;
      font-size: 14px;
      color: var(--text-dim);
      display: flex;
      align-items: flex-start;
      gap: 8px;
    }

    .key-points li::before {
      content: '>';
      color: var(--accent);
      font-family: 'JetBrains Mono', monospace;
      font-weight: 600;
      flex-shrink: 0;
    }

    footer {
      text-align: center;
      padding: 40px 24px;
      color: var(--text-dim);
      font-size: 13px;
      border-top: 1px solid var(--border);
    }

    footer a {
      color: var(--accent);
      text-decoration: none;
    }

    @media (max-width: 768px) {
      .section-header { flex-wrap: wrap; }
      .section-subtitle { margin-left: 0; }
    }
  </style>
</head>
<body>
  <slot />

  <footer>
    <p>Built for NM i AI 2026 &mdash; Solo entry &mdash; <a href="https://nmai.no" target="_blank">nmai.no</a></p>
  </footer>
</body>
</html>
