---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import StatsBar from "../components/StatsBar.astro";
import ScoreChart from "../components/ScoreChart.astro";
import Pipeline from "../components/Pipeline.astro";
import ModelBlendTable from "../components/ModelBlendTable.astro";

const rounds = [
  { r: 7, score: 59.8, rank: 88, teams: 199, weight: 1.41 },
  { r: 8, score: 71.6, rank: 87, teams: 214, weight: 1.48 },
  { r: 9, score: 90.9, rank: 21, teams: 221, weight: 1.55 },
  { r: 10, score: 68.7, rank: 103, teams: 238, weight: 1.63 },
  { r: 11, score: 0, rank: 0, teams: 0, weight: 1.71, missed: true },
  { r: 12, score: 0, rank: 0, teams: 0, weight: 1.80, missed: true },
  { r: 13, score: 0, rank: 0, teams: 0, weight: 1.89, missed: true },
  { r: 14, score: 57.3, rank: 141, teams: 244, weight: 1.98 },
  { r: 15, score: 85.5, rank: 102, teams: 262, weight: 2.08 },
  { r: 16, score: 80.6, rank: 100, teams: 272, weight: 2.18 },
  { r: 17, score: 72.8, rank: 156, teams: 283, weight: 2.29 },
  { r: 18, score: 47.7, rank: 179, teams: 265, weight: 2.41 },
  { r: 19, score: 58.9, rank: 161, teams: 228, weight: 2.53 },
  { r: 20, score: 60.7, rank: 153, teams: 181, weight: 2.65 },
  { r: 21, score: 82.3, rank: 136, teams: 225, weight: 2.79 },
  { r: 22, score: 73.3, rank: 163, teams: 278, weight: 2.93 },
  { r: 23, score: 51.1, rank: 189, teams: 285, weight: 3.07 },
];

const submitted = rounds.filter(r => !r.missed);

const blendRows = [
  { terrain: "Empty / Plains", model: "Bucket", blend: "100%" },
  { terrain: "Settlement", model: "MLP + Sim", blend: "10% + 90%" },
  { terrain: "Port", model: "Sim", blend: "100%" },
  { terrain: "Ruin", model: "CNN", blend: "100%", best: true },
  { terrain: "Forest", model: "Sim + CNN", blend: "60% + 40%" },
  { terrain: "Mountain", model: "CNN", blend: "100%", best: true },
];

const pipelineSteps = [
  { label: "Fetch Grid" },
  { label: "Run Sim (200 rollouts)", highlight: true },
  { label: "Submit Safety Net" },
  { label: "50 Queries", highlight: true },
  { label: "Tune Params" },
  { label: "Re-simulate" },
  { label: "Bayesian Blend", highlight: true },
  { label: "Final Submit" },
];
---

<BaseLayout>
  <Hero
    badge="NM i AI 2026 — Norwegian AI Championship"
    title="Three Challenges,"
    highlight="One Wild Ride"
    subtitle="Solo entry across all three tracks: Norse world simulation, accounting API agents, and grocery shelf detection."
  />

  <div class="container">

    <StatsBar stats={[
      { value: "3", label: "Challenges" },
      { value: String(submitted.length), label: "Rounds Submitted" },
      { value: "90.9", label: "Best Score" },
      { value: "#21", label: "Best Rank" },
      { value: "C++", label: "Primary Lang" },
    ]} />

    <!-- CHALLENGE 1: A* ISLAND -->
    <div class="section">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2>A* Island</h2>
        <span class="section-subtitle">Terrain Prediction</span>
      </div>

      <p class="section-desc">
        Predict probability distributions over 6 terrain classes for every cell in a 40x40 grid
        after 50 simulated years of a hidden Norse world simulation. Scored via entropy-weighted KL divergence.
        Each round had 5 seeds, 50 queries, and a 2-hour window.
      </p>

      <div class="tech-stack">
        <span class="tech-pill">C++17</span>
        <span class="tech-pill">Monte Carlo Sim</span>
        <span class="tech-pill">CMA-ES Optimization</span>
        <span class="tech-pill">U-Net / CNN</span>
        <span class="tech-pill">MLP</span>
        <span class="tech-pill">Nelder-Mead Tuning</span>
        <span class="tech-pill">TypeScript</span>
        <span class="tech-pill">Deno</span>
      </div>

      <ScoreChart rounds={rounds} />

      <div class="card-grid">
        <div class="card">
          <h3>Monte Carlo Simulator <span class="card-tag tag-cpp">C++</span></h3>
          <p>
            Full Norse world sim — settlements grow, trade, raid, build ports, collapse.
            40 CMA-ES-calibrated params. 200-2000 rollouts per seed.
            The backbone of the approach, best on most rounds.
          </p>
        </div>
        <div class="card">
          <h3>U-Net / CNN <span class="card-tag tag-cpp">C++</span></h3>
          <p>
            2-level U-Net with skip connections, instance norm, and residual learning.
            Learns corrections on top of sim predictions. 8x data augmentation.
            Best for mountains and ruins.
          </p>
        </div>
        <div class="card">
          <h3>Bucket Predictor <span class="card-tag tag-cpp">C++</span></h3>
          <p>
            Histogram-based predictor from training data. Groups cells by initial terrain
            and neighborhood features. Surprisingly strong baseline for empty/plains.
          </p>
        </div>
        <div class="card">
          <h3>MLP <span class="card-tag tag-cpp">C++</span></h3>
          <p>
            2-layer neural net with 23 hand-crafted features per cell
            (position, neighbors, coastal distance, etc). Handles settlements well
            when blended with sim.
          </p>
        </div>
      </div>

      <Pipeline steps={pipelineSteps} />

      <ModelBlendTable rows={blendRows} />

      <div class="dashboard-link-card">
        <h3>Interactive Dashboard</h3>
        <p>All rounds, all models, cell-level inspection of predictions vs ground truth.</p>
        <a href="/dashboard/competition">View competition dashboard &rarr;</a>
      </div>
    </div>

    <!-- CHALLENGE 2: TRIPLETEX -->
    <div class="section">
      <div class="section-header">
        <span class="section-number">02</span>
        <h2>Tripletex</h2>
        <span class="section-subtitle">Accounting API Agent</span>
      </div>

      <p class="section-desc">
        Build an AI agent that receives natural-language accounting tasks and executes them
        via the Tripletex REST API. Tasks range from creating invoices and employees to reversing vouchers
        and handling travel expenses.
      </p>

      <div class="tech-stack">
        <span class="tech-pill">TypeScript</span>
        <span class="tech-pill">Cloudflare Workers</span>
        <span class="tech-pill">Hono</span>
        <span class="tech-pill">Vercel AI SDK</span>
        <span class="tech-pill">Gemini</span>
      </div>

      <div class="challenge-card">
        <h3>AI-Powered API Agent</h3>
        <p class="subtitle">Natural language &rarr; Tripletex API calls</p>
        <span class="result-badge blue">6 / 30 tasks solved</span>
        <ul class="key-points">
          <li>Cloudflare Worker receives task descriptions, LLM decides which API calls to make</li>
          <li>Gemini as the brain — tool-use loop with structured Tripletex API bindings</li>
          <li>Biggest challenge: undocumented API quirks — <code>/orderline</code> doesn't exist (it's <code>/order/orderline</code>), action endpoints use PUT not POST</li>
          <li>Voucher postings need <code>row &ge; 1</code> (row 0 is system-reserved) — cost multiple failed submissions to discover</li>
          <li>Employee POST requires <code>department</code> and <code>userType</code> as mandatory fields — not documented</li>
        </ul>
      </div>
    </div>

    <!-- CHALLENGE 3: NORGESGRUPPEN -->
    <div class="section">
      <div class="section-header">
        <span class="section-number">03</span>
        <h2>NorgesGruppen</h2>
        <span class="section-subtitle">Object Detection</span>
      </div>

      <p class="section-desc">
        Detect and classify grocery products on store shelves. 356 product categories,
        reference images of each product from 7 angles. Scored on mAP.
      </p>

      <div class="tech-stack">
        <span class="tech-pill">Python</span>
        <span class="tech-pill">YOLOv8m</span>
        <span class="tech-pill">ONNX Runtime</span>
        <span class="tech-pill">RTX 3090 Ti</span>
      </div>

      <div class="challenge-card">
        <h3>Shelf Product Detection</h3>
        <p class="subtitle">YOLOv8 trained on grocery shelf images</p>
        <span class="result-badge silver">0.5946 mAP</span>
        <span class="result-badge blue">Top was ~0.85</span>
        <ul class="key-points">
          <li>Fine-tuned YOLOv8m on annotated shelf images, exported to ONNX for sandbox compatibility</li>
          <li>327 product reference images (7 angles each) were available but never utilized — ran out of time</li>
          <li>Started too late — model training is the bottleneck in CV competitions</li>
          <li>Lesson learned: reference images could have boosted classification significantly</li>
        </ul>
      </div>
    </div>

    <!-- KEY TAKEAWAYS -->
    <div class="section">
      <div class="section-header">
        <span class="section-number">++</span>
        <h2>Key Takeaways</h2>
      </div>

      <div class="card-grid">
        <div class="card">
          <h3>C++ is underrated for ML</h3>
          <p>
            All four A* Island models (sim, CNN, MLP, bucket) are pure C++17 with zero dependencies.
            Compiles in seconds, runs fast, full control. No PyTorch, no CUDA — just math.
          </p>
        </div>
        <div class="card">
          <h3>Calibration matters more than architecture</h3>
          <p>
            CMA-ES parameter optimization on the simulator gave bigger gains than switching model architectures.
            The R9 score of 90.9 was mostly calibration, not model complexity.
          </p>
        </div>
        <div class="card">
          <h3>Query observations are gold</h3>
          <p>
            Using 50 queries to observe actual simulation outcomes, then Nelder-Mead tuning per-round
            gave +19 points on hard rounds. Real data beats priors.
          </p>
        </div>
        <div class="card">
          <h3>Ensemble &gt; single model</h3>
          <p>
            Different models excel at different terrain classes. The optimal blend uses bucket for empty,
            sim for ports, CNN for mountains, and sim+MLP for settlements.
          </p>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .dashboard-link-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 32px;
    transition: border-color 0.2s;
  }

  .dashboard-link-card:hover { border-color: var(--accent); }

  .dashboard-link-card h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .dashboard-link-card p {
    font-size: 14px;
    color: var(--text-dim);
    margin-bottom: 12px;
  }

  .dashboard-link-card a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--accent);
    text-decoration: none;
  }

  .dashboard-link-card a:hover { text-decoration: underline; }
</style>
