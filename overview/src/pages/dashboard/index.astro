---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
---

<BaseLayout title="A* Island — Dashboards">
  <Hero
    badge="A* Island — Dashboards"
    title="Model"
    highlight="Dashboards"
    subtitle="Compare predictions from competition time vs updated models trained on all available data."
  />

  <div class="container">
    <div class="dashboard-grid">
      <a href="/dashboard/competition" class="dashboard-link">
        <div class="dashboard-card">
          <span class="badge">original</span>
          <h3>During Competition</h3>
          <p>Predictions as submitted during each round, using the models and calibration available at the time.</p>
        </div>
      </a>
      <a href="/dashboard/updated" class="dashboard-link">
        <div class="dashboard-card upcoming">
          <span class="badge">new</span>
          <h3>Updated Models</h3>
          <p>Re-run predictions with improved models trained on all 23 rounds of ground truth data.</p>
        </div>
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
    margin-bottom: 80px;
  }

  .dashboard-link {
    text-decoration: none;
    color: inherit;
  }

  .dashboard-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .dashboard-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .dashboard-card.upcoming {
    border-style: dashed;
    opacity: 0.7;
  }

  .badge {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--accent-glow);
    color: var(--accent);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  h3 {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  p {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.6;
  }
</style>
